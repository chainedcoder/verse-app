generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String              @id @default(cuid())
  name                   String?
  email                  String?             @unique
  emailVerified          DateTime?
  password               String?
  image                  String?
  bio                    String?
  location               String?
  isPrivateAccount       Boolean             @default(false)
  mfaEnabled             Boolean             @default(false)
  emailNotifications     Boolean             @default(true)
  role                   String              @default("USER")
  status                 String              @default("ACTIVE")
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  immersiveMode          Boolean             @default(false)
  theme                  String              @default("system")
  username               String?             @unique
  website                String?
  twoFactorMethod        String?
  twoFactorSecret        String?
  currentChallenge       String?
  exportPreferences      Json?
  permissions            Json?
  permissionGroupId      String?
  coverImage             String?
  firstName              String?
  jobTitle               String?
  lastName               String?
  notificationMatrix     Json?
  plan                   String              @default("FREE")
  preferences            Json?
  professionalInfo       Json?
  socialLinks            Json?
  stripeCurrentPeriodEnd DateTime?
  stripeCustomerId       String?
  stripePriceId          String?
  stripeSubscriptionId   String?
  deletedAt              DateTime?
  aiGenerationQueues     AIGenerationQueue[]
  accounts               Account[]
  apiKeys                ApiKey[]
  authenticators         Authenticator[]
  collections            Collection[]
  comments               Comment[]
  following              Follow[]            @relation("follower")
  followers              Follow[]            @relation("following")
  likes                  Like[]
  logEvents              LogEvent[]
  actorNotifications     Notification[]      @relation("actorNotifications")
  notifications          Notification[]      @relation("userNotifications")
  poems                  Poem[]
  reportsReceived        Report[]            @relation("reportedUser")
  reportsSubmitted       Report[]            @relation("reporter")
  sessions               Session[]
  threadMemberships      ThreadMembership[]
  ticketsAssigned        Ticket[]            @relation("ticketAssignee")
  ticketsReported        Ticket[]            @relation("ticketReporter")
  permissionGroup        PermissionGroup?    @relation(fields: [permissionGroupId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  browser      String?
  device       String?
  ipAddress    String?
  lastActive   DateTime @default(now())
  location     String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Poem {
  id               String         @id @default(cuid())
  title            String
  excerpt          String
  fullText         String
  featured         Boolean        @default(false)
  status           String         @default("PUBLISHED")
  isPrivate        Boolean        @default(false)
  authorId         String
  createdAt        DateTime       @default(now())
  vibeConfig       Json?
  customAuthorName String?
  comments         Comment[]
  likes            Like[]
  notifications    Notification[] @relation("poemNotifications")
  author           User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  images           PoemImage[]
  reports          Report[]       @relation("reportedPoem")
  collections      Collection[]   @relation("CollectionPoems")
  tags             Tag[]          @relation("PoemTags")
}

model PoemImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  poemId    String
  createdAt DateTime @default(now())
  poem      Poem     @relation(fields: [poemId], references: [id], onDelete: Cascade)
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  poems     Poem[]   @relation("PoemTags")
}

model Like {
  id        String   @id @default(cuid())
  poemId    String
  userId    String
  createdAt DateTime @default(now())
  poem      Poem     @relation(fields: [poemId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([poemId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  poemId    String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  poem      Poem     @relation(fields: [poemId], references: [id], onDelete: Cascade)
  reports   Report[] @relation("reportedComment")

  @@index([poemId, createdAt])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Collection {
  id          String   @id @default(cuid())
  name        String
  description String?
  isPublic    Boolean  @default(true)
  authorId    String
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  poems       Poem[]   @relation("CollectionPoems")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  actorId   String
  poemId    String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  actor     User     @relation("actorNotifications", fields: [actorId], references: [id], onDelete: Cascade)
  poem      Poem?    @relation("poemNotifications", fields: [poemId], references: [id], onDelete: Cascade)
  user      User     @relation("userNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Report {
  id                String   @id @default(cuid())
  reporterId        String
  reportedUserId    String?
  reportedPoemId    String?
  reportedCommentId String?
  reason            String
  status            String   @default("PENDING")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  reportedComment   Comment? @relation("reportedComment", fields: [reportedCommentId], references: [id], onDelete: Cascade)
  reportedPoem      Poem?    @relation("reportedPoem", fields: [reportedPoemId], references: [id], onDelete: Cascade)
  reportedUser      User?    @relation("reportedUser", fields: [reportedUserId], references: [id], onDelete: Cascade)
  reporter          User     @relation("reporter", fields: [reporterId], references: [id], onDelete: Cascade)
}

model Authenticator {
  credentialID         String  @id
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, credentialID])
}

model PermissionGroup {
  id          String   @id @default(cuid())
  name        String   @unique
  color       String   @default("blue")
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  hashedKey  String
  prefix     String
  userId     String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Ticket {
  id          String   @id @default(cuid())
  status      String
  priority    String
  category    String
  requestType String
  title       String
  snippet     String
  reporterId  String
  assigneeId  String?
  entityType  String?
  entityId    String?
  entityName  String?
  threadId    String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  assignee    User?    @relation("ticketAssignee", fields: [assigneeId], references: [id])
  reporter    User     @relation("ticketReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  thread      Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model Thread {
  id          String              @id @default(cuid())
  type        String
  pinned      Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  aiQueues    AIGenerationQueue[]
  messages    Message[]
  memberships ThreadMembership[]
  ticket      Ticket?
}

model Message {
  id         String   @id @default(cuid())
  threadId   String
  senderId   String
  senderType String
  content    String
  parentId   String?
  createdAt  DateTime @default(now())
  thread     Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model ThreadMembership {
  id                 String    @id @default(cuid())
  threadId           String
  userId             String
  role               String
  joinedAt           DateTime  @default(now())
  leftAt             DateTime?
  historyGrantedFrom DateTime?
  historyGrantedTo   DateTime?
  thread             Thread    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LogEvent {
  id          String   @id @default(cuid())
  timestamp   DateTime @default(now())
  entityName  String
  operation   String
  changes     Json?
  severity    String   @default("MEDIUM")
  accessLevel String   @default("USER")
  tags        String[]
  actorId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  actor       User?    @relation(fields: [actorId], references: [id])
}

model AIGenerationQueue {
  id           String   @id @default(cuid())
  threadId     String
  agentId      String
  draftContent String
  status       String
  createdAt    DateTime @default(now())
  agent        User     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  thread       Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
}
